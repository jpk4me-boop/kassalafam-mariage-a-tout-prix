# KASSALAFAM — MARIAGE À TOUT PRIX
# Copier ce fichier en `.env.local` et renseigner les valeurs de votre projet Supabase.
# NE JAMAIS committer `.env.local`. NE JAMAIS exposer la clé service_role côté front.

# --- Public (navigateur) -----------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre-cle-anon-publique

# --- Serveur uniquement (JAMAIS de préfixe NEXT_PUBLIC_) ----------------------
# Clé service_role : bypasse la RLS. Utilisée seulement APRÈS validation du rôle.
SUPABASE_SERVICE_ROLE_KEY=votre-cle-service-role

# Back-office : allowlists d'UUID auth.users, séparés par des virgules.
# ADMIN_USER_IDS       → administrateurs (modération courante).
# SUPER_ADMIN_USER_IDS → super administrateurs (actions sensibles). Tout super
#                        administrateur est AUSSI administrateur (hiérarchie).
# Ne jamais préfixer NEXT_PUBLIC_ : ces UUID ne doivent pas atteindre le client.
ADMIN_USER_IDS=uuid-admin-1,uuid-admin-2
SUPER_ADMIN_USER_IDS=uuid-super-admin
